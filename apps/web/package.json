{
  "name": "web",
  "version": "0.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev & partykit dev",
    "dev:vite": "vite dev",
    "dev:party": "partykit dev",
    "dev-local": "vite dev --host 0.0.0.0 --port 8080",
    "build": "svelte-kit sync && vite build",
    "build:party": "partykit build",
    "deploy:party": "partykit deploy",
    "preview": "vite preview",
    "start": "node build",
    "tsc": "svelte-kit sync && tsc",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:xvfb": "pnpm run test:unit && pnpm run test:integration:headed",
    "test:integration:headed": "playwright test --headed",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test:integration": "playwright test",
    "test:unit": "vitest",
    "generate": "drizzle-kit generate --config ./src/lib/db/app/drizzle.config.app.ts",
    "migrate": "drizzle-kit migrate --config ./src/lib/db/app/drizzle.config.app.ts",
    "push": "drizzle-kit push --config ./src/lib/db/app/drizzle.config.app.ts",
    "drop": "drizzle-kit drop --config ./src/lib/db/app/drizzle.config.app.ts",
    "pull": "drizzle-kit pull --config ./src/lib/db/app/drizzle.config.app.ts",
    "studio": "drizzle-kit studio --config ./src/lib/db/app/drizzle.config.app.ts",
    "assets:generate": "node scripts/assets-generate.js",
    "assets:upload": "node scripts/assets-upload.js",
    "postinstall": "svelte-kit sync"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "=3.712.0",
    "@aws-sdk/s3-request-presigner": "=3.712.0",
    "@libsql/client": "^0.17.3",
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@sentry/sveltekit": "^10.55.0",
    "@tabler/icons-svelte": "^3.44.0",
    "@tableslayer/stage": "workspace:*",
    "@tableslayer/ui": "workspace:*",
    "@tanstack/svelte-query": "^6.1.33",
    "@types/ws": "^8.18.1",
    "arctic": "^3.7.0",
    "chroma-js": "^3.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lib0": "^0.2.117",
    "marked": "^18.0.4",
    "mime": "^4.1.0",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "partykit": "^0.0.115",
    "resend": "^6.12.4",
    "slugify": "^1.6.9",
    "stripe": "^22.2.0",
    "uuid": "^14.0.0",
    "vite-sveltekit-node-ws": "^0.0.8",
    "ws": "^8.21.0",
    "y-partykit": "^0.0.33",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tableslayer/eslint-config": "workspace:*",
    "@tableslayer/tsconfig": "workspace:*",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "postprocessing": "6.39.1",
    "svelte": "5.56.0",
    "svelte-check": "^4.4.8",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
