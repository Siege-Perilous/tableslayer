{
  "name": "@tableslayer/ui",
  "version": "0.1.4",
  "license": "FSL-1.1-ALv2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Siege-Perilous/tableslayer.git",
    "directory": "packages/ui"
  },
  "author": "Siege Perilous LLC",
  "keywords": [
    "svelte",
    "svelte5",
    "components",
    "ui",
    "tableslayer"
  ],
  "homepage": "https://github.com/Siege-Perilous/tableslayer/tree/main/packages/ui",
  "scripts": {
    "dev": "svelte-package --watch",
    "build": "svelte-kit sync && vite build && npm run package",
    "preview": "vite preview",
    "tsc": "tsc",
    "package": "svelte-kit sync && svelte-package && typedoc",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "typedoc": "typedoc",
    "postinstall": "svelte-kit sync && pnpm run package"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles/*.css": {
      "import": "./dist/styles/*.css",
      "require": "./dist/styles/*.css"
    },
    "./typedoc.json": {
      "import": "./typedocgen.json",
      "require": "./typedocgen.json"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "@melt-ui/svelte": "^0.86.2",
    "@sveltejs/kit": "^2.16.0",
    "svelte": "^5.19.0"
  },
  "devDependencies": {
    "@magidoc/plugin-svelte-marked": "^6.3.0",
    "@melt-ui/svelte": "^0.86.6",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.52.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tableslayer/eslint-config": "workspace:*",
    "@tableslayer/tsconfig": "workspace:*",
    "@types/chroma-js": "^3.1.2",
    "@types/marked": "^6.0.0",
    "@types/three": "0.182.0",
    "marked": "^17.0.2",
    "svelte": "5.51.2",
    "svelte-check": "^4.4.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@tabler/icons-svelte": "^3.36.1",
    "@threlte/core": "8.3.1",
    "@threlte/extras": "9.7.1",
    "@tiptap/core": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-typography": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "chroma-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "gifuct-js": "^2.1.2",
    "lazy-brush": "^2.0.2",
    "postprocessing": "6.38.2",
    "shiki": "^3.22.0",
    "three": "0.182.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module"
}
