{
  "name": "@tableslayer/ui",
  "version": "0.2.2",
  "license": "FSL-1.1-ALv2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Siege-Perilous/tableslayer.git",
    "directory": "packages/ui"
  },
  "author": "Siege Perilous LLC",
  "keywords": [
    "svelte",
    "svelte5",
    "components",
    "ui",
    "tableslayer"
  ],
  "homepage": "https://github.com/Siege-Perilous/tableslayer/tree/main/packages/ui",
  "scripts": {
    "dev": "svelte-package --watch",
    "build": "svelte-kit sync && vite build && npm run package",
    "preview": "vite preview",
    "tsc": "svelte-kit sync && tsc",
    "package": "svelte-kit sync && svelte-package && typedoc",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "typedoc": "typedoc"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles/*.css": {
      "import": "./dist/styles/*.css",
      "require": "./dist/styles/*.css"
    },
    "./typedoc.json": {
      "import": "./typedocgen.json",
      "require": "./typedocgen.json"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "@sveltejs/kit": "^2.16.0",
    "svelte": "^5.19.0"
  },
  "devDependencies": {
    "@magidoc/plugin-svelte-marked": "^6.4.4",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tableslayer/eslint-config": "workspace:*",
    "@tableslayer/tsconfig": "workspace:*",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^26.0.1",
    "@types/marked": "^6.0.0",
    "marked": "^18.0.5",
    "svelte": "5.56.4",
    "svelte-check": "^4.7.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@tabler/icons-svelte": "^3.44.0",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "chroma-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "shiki": "^4.3.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module"
}
